# URL de l'API FastAPI (laisser vide pour utiliser le proxy Vite /api en dev)
# En prod, le front est servi en statique (serve -s dist, sans proxy /api) : il faut
# donc une origine absolue vers l'API. La valeur de prod vit dans web/.env.production
# (inlinée AU BUILD par Vite). Ex. : VITE_API_URL=https://api-keepou.galaxou.com
VITE_API_URL=
