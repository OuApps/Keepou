# Keepou off-site backup runner — environment (epic E9).
#
# On Railway these are the *service variables* of the scheduled backup service.
# Locally, copy to `.env` next to it and `set -a; . ./.env; set +a` before
# running ../../scripts/backup.sh. NEVER commit real secrets (see .gitignore).

# --- Database (source) ------------------------------------------------------
# On Railway, reference the Postgres plugin's INTERNAL connection string so the
# DB is never exposed publicly, e.g. ${{ Postgres.DATABASE_URL }}.
# A SQLAlchemy `+psycopg` / `+asyncpg` driver suffix is stripped automatically.
DATABASE_URL=postgresql://postgres:password@localhost:5432/keepou

# --- Scaleway Object Storage (off-site target) ------------------------------
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
BACKUP_BUCKET=keepou-backups
# Region + endpoint. Endpoint defaults to https://s3.$SCW_REGION.scw.cloud, so
# usually only SCW_REGION is needed. Point SCW_ENDPOINT elsewhere (R2/B2/MinIO)
# to swap providers by env alone.
SCW_REGION=fr-par
# SCW_ENDPOINT=https://s3.fr-par.scw.cloud

# --- Retention knobs (optional; defaults shown) -----------------------------
# 3-tier scheme: every run lands in hourly/; the first run of each UTC day is
# also promoted to daily/, and the first run of WEEKLY_DOW to weekly/. The cron
# cadence is set on the Railway service (railway.json → deploy.cronSchedule,
# default hourly "0 * * * *"), NOT here.
# HOURLY_RETENTION=48      # fine-grained dumps to keep (48 = 2 days at hourly cadence)
# DAILY_RETENTION=7        # daily dumps to keep
# WEEKLY_RETENTION=4       # weekly dumps to keep
# WEEKLY_DOW=7             # ISO day-of-week (1=Mon…7=Sun) that also lands a weekly
# HOURLY_PREFIX=hourly     # fine-grained tier prefix
# BACKUP_PREFIX=keepou     # dump-name prefix inside the bucket
