# Base de données — SQLite par défaut en dev ; PostgreSQL recommandé en prod.
DATABASE_URL=sqlite:///./keepou.db

# Secret de signature des sessions (cookie signé). À régénérer en prod.
SESSION_SECRET=dev-change-me

# Origines autorisées (front Vite) pour CORS, séparées par des virgules.
CORS_ORIGINS=http://localhost:5173
