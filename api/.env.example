# Database — SQLite by default in dev; PostgreSQL in prod (Railway).
# Railway's Postgres plugin exposes `postgresql://…`; the app normalizes it to
# `postgresql+psycopg://…` automatically (see app/config.py), so paste it as-is.
DATABASE_URL=sqlite:///./keepou.db

# JWT signing secret (signs the access + refresh tokens). Generate a strong value
# in prod, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
SESSION_SECRET=dev-change-me

# Public origins of the two services — the single source of truth for the absolute
# URLs the backend builds (CORS origin, public MCP URL, share links). In prod these
# are the paired custom (Cloudflare) sub-domains — NEVER a *.up.railway.app domain.
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
# In prod, e.g.:
# FRONTEND_URL=https://keepou.galaxou.com
# API_BASE_URL=https://api-keepou.galaxou.com

# Allowed CORS origins (the web front), comma-separated. Defaults to FRONTEND_URL,
# so you usually only set it to list SEVERAL origins. It must match the front's
# VITE_API_URL pairing. Credentials are off (bearer token, not cookie), so if auth
# ever moves to a cookie this needs allow_credentials=True in app/main.py.
# CORS_ORIGINS=https://keepou.galaxou.com

# Optional — JWT bearer token TTLs (defaults: 15 min access, 30 days refresh).
# ACCESS_TOKEN_TTL_MINUTES=15
# REFRESH_TOKEN_TTL_DAYS=30

# Agent access over MCP (E13) — the streamable-HTTP MCP server mounted at /mcp,
# authenticated by Personal Access Tokens. MCP_PUBLIC_URL is the externally
# reachable endpoint; it defaults to API_BASE_URL + /mcp, so setting API_BASE_URL
# above is enough in prod. Leave DNS-rebinding protection off unless the server is
# bound to localhost (it is a public, bearer-authenticated API). Set
# MCP_ENABLED=false to disable agent access.
# MCP_ENABLED=true
# MCP_PUBLIC_URL=https://api-keepou.galaxou.com/mcp
# MCP_DNS_REBINDING_PROTECTION=false
