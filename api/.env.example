# Database — SQLite by default in dev; PostgreSQL in prod (Railway).
# Railway's Postgres plugin exposes `postgresql://…`; the app normalizes it to
# `postgresql+psycopg://…` automatically (see app/config.py), so paste it as-is.
DATABASE_URL=sqlite:///./keepou.db

# JWT signing secret (signs the access + refresh tokens). Generate a strong value
# in prod, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
SESSION_SECRET=dev-change-me

# Allowed CORS origins (the web front), comma-separated. In prod: the exact
# public URL of the keepou-web service (its custom domain), e.g.
# CORS_ORIGINS=https://keepou.galaxou.com — it must match the front's VITE_API_URL
# pairing. Credentials are off (bearer token, not cookie).
CORS_ORIGINS=http://localhost:5173

# Optional — JWT bearer token TTLs (defaults: 15 min access, 30 days refresh).
# ACCESS_TOKEN_TTL_MINUTES=15
# REFRESH_TOKEN_TTL_DAYS=30

# Agent access over MCP (E13) — the streamable-HTTP MCP server mounted at /mcp,
# authenticated by Personal Access Tokens. Set MCP_PUBLIC_URL to the externally
# reachable endpoint in prod (the API public URL + /mcp). Leave DNS-rebinding
# protection off unless the server is bound to localhost (it is a public,
# bearer-authenticated API). Set MCP_ENABLED=false to disable agent access.
# MCP_ENABLED=true
# MCP_PUBLIC_URL=http://localhost:8000/mcp
# MCP_DNS_REBINDING_PROTECTION=false
