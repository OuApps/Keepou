# Copy this file to .env and fill it in before `docker compose up -d`.

# Secret that signs the auth tokens — keep it private and use a long random value.
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=

# Password for the bundled PostgreSQL container. It is only reachable from the
# other containers, but set your own value anyway.
POSTGRES_PASSWORD=keepou

# Host port the app is served on.
APP_PORT=8080

# Public origin the app is reached at. Behind a domain, set this to that URL
# (e.g. https://keep.example.org).
APP_ORIGIN=http://localhost:8080
